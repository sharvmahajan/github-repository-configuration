{
  "scanSettings": {
    "baseBranches": ["{{ default_branch }}"]
  },
  "checkRunSettings": {
    "vulnerableCheckRunConclusionLevel": "failure",
    "displayMode": "diff"
  },
  "issueSettings": {
    "minSeverityLevel": "LOW",
    "issueType": "DEPENDENCY"
  },
  "aggregateProjectName": "{{ repo_name }}"
}